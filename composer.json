{
    "name": "translatify/translatify",
    "description": "Tiny English-as-key i18n helper + drop-in editor for FlightPHP/RedBean projects",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "ext-intl": "*"
    },
    "autoload": {
        "psr-4": {
            "Translatify\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "bin": [
        "bin/i18n-scan",
        "bin/i18n-find-untranslated"
    ]
}
